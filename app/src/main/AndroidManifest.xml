<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Saving images to the gallery on pre-Q only; Q+ uses scoped MediaStore (no permission). -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <!-- Torch control (CameraManager.setTorchMode) needs no permission, only declared here
         so Play/app stores know the flash unit is optional, not required, hardware. -->
    <uses-feature android:name="android.hardware.camera.flash" android:required="false" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <!-- Normal permission (auto-granted), lets AlarmToolProvider create alarms without
         the clock app's UI showing on devices that support EXTRA_SKIP_UI. -->
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM" />

    <!-- Package-visibility (API 30+): lets AlarmToolProvider's resolveActivity()/
         startActivity() find whatever clock app is installed to handle AlarmClock
         intents (set alarm/timer, show alarms, dismiss/snooze). -->
    <queries>
        <!-- Special-cased by the platform: a <queries> intent signature matching
             MAIN/LAUNCHER makes every app with a launcher icon visible to
             queryIntentActivities()/getLaunchIntentForPackage(), on every flavor,
             with no permission review and no QUERY_ALL_PACKAGES declaration. Backs
             PackageQueryToolProvider's list_installed_apps and AppLaunchToolProvider's
             open_app tools.
             See: https://developer.android.com/training/package-visibility -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SET_ALARM" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SET_TIMER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SHOW_ALARMS" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DISMISS_ALARM" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SNOOZE_ALARM" />
        </intent>
    </queries>

    <application
        android:name=".AgoraApplication"
        android:allowBackup="false"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Agora.Starting"
        android:localeConfig="@xml/locales_config">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="@string/app_name"
            android:theme="@style/Theme.Agora"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Lets the system "App info" page show a shortcut (usually a gear icon)
                that opens straight to Agora's own in-app settings screen, instead of
                only the launcher entry point.
            -->
            <intent-filter>
                <action android:name="android.intent.action.APPLICATION_PREFERENCES" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!--
                Share target: lets other apps' share sheets send text/files to Agora.
                Shared text is prefilled into the prompt input; shared images/videos/docs
                are queued as attachments (mime whitelist mirrors util/FileValidator.kt
                for docs, plus image/* and video/* which aren't size/type restricted).
                See MainActivity.registerIfShareRequest() / assistant/ for the capture path.
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/*" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="application/pdf" />
                <data android:mimeType="application/json" />
                <data android:mimeType="application/xml" />
                <data android:mimeType="application/yaml" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/*" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="application/pdf" />
                <data android:mimeType="application/json" />
                <data android:mimeType="application/xml" />
                <data android:mimeType="application/yaml" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <provider
            android:name=".sandbox.SandboxDocumentsProvider"
            android:authorities="${applicationId}.documents"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>

        <service
            android:name=".service.AgoraForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!--
            Digital assistant integration. Together these three services satisfy the
            android.app.role.ASSISTANT role requirements so Agora can be selected in
            Settings > Apps > Default apps > Digital assistant app. See assistant/ for
            the actual assist-capture logic; the role itself grants no functionality
            beyond making Agora launchable via the system assist gesture (long-press
            home / power, or the assist swipe gesture).
        -->
        <service
            android:name=".assistant.AgoraVoiceInteractionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/interaction_service" />
        </service>

        <service
            android:name=".assistant.AgoraVoiceInteractionSessionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true" />

        <!--
            Stub recognizer: required because voice_interaction_service metadata must
            reference a RecognitionService in this package (the system binds to it).
            Agora does not do speech-to-text here — screen text is captured via
            AssistStructure instead — so this immediately reports an error if the
            system ever actually starts listening on it.
        -->
        <service
            android:name=".assistant.AgoraRecognitionService"
            android:permission="android.permission.BIND_RECOGNITION_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
        </service>

        <!--
            Single notification-listener backing both NotificationToolProvider's
            list_notifications/get_notification/interact_notification/dismiss_notification
            tools and MediaControlToolProvider's MediaSessionManager.getActiveSessions() call
            (which requires the caller to be an enabled notification listener) — see
            service/AgoraNotificationAccessService.kt. One special-access grant in
            Settings > Apps > Special app access > Notification access covers both tools;
            there is no runtime-permission dialog for this.
        -->
        <service
            android:name=".service.AgoraNotificationAccessService"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>

</manifest>
